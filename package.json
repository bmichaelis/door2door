    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.21.0",
    "next": "^15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
